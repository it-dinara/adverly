{
  "compilerOptions": {
    "target": "ES5",
    "module": "ESNext",
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "baseUrl": "./",
    "paths": {
      "Redux/*": ["src/redux/*"],
      "AxiosInstance": ["src/axios-adverly.ts"],
      "Pages/*": ["src/pages/*"],
      "Types/*": ["src/types/*"],
      "Categories/*": ["src/components/Categories/*"],
      "Utils/*": ["src/utils/*"]
    },
    "plugins": [
      {
        "transform": "typescript-transform-paths"
      },
      {
        "transform": "typescript-transform-paths",
        "afterDeclarations": true
      },
      { "name": "typescript-plugin-css-modules" }
    ]
  },
  "include": ["src/**/*", "src/index.tsx", "src/utils"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
